{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "my-portfolio",
  "main": "./dist/_worker.js/index.js",
  "compatibility_date": "2025-05-21",
  "compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
  },
  "observability": {
    "enabled": true,
  },
}

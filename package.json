{
  "name": "my-portfolio",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && tsc --noEmit && bun run build:worker",
    "build:worker": "rm -rf .output && mkdir -p .output && cp -R dist/client .output/public && cp -R dist/server .output/server && cp .output/server/index.js .output/server/index.mjs",
    "preview": "vite preview",
    "start": "wrangler dev",
    "deploy": "bun run build && wrangler deploy",
    "cf:typegen": "wrangler types"
  },
  "dependencies": {
    "@tanstack/react-router": "^1.168.22",
    "@tanstack/react-start": "^1.167.41",
    "lucide-react": "^0.563.0",
    "marked": "^18.0.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.29.0",
    "@types/node": "^22.10.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "wrangler": "^4.74.0"
  }
}

---
import { ArrowLeft, ExternalLink } from "lucide-react";
import EmptyState from "@/components/astro/EmptyState.astro";
import ReadmeArticle from "@/components/astro/ReadmeArticle.astro";
import { getRepoReadmeData } from "@/lib/server/github";
import { renderReadmeToHtml } from "@/lib/server/markdown";
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageShell from "@/layouts/PageShell.astro";

export const prerender = false;

const slug = Astro.params.slug ?? "";
const pathname = `/projects/${slug}`;
const isValidSlug = /^[A-Za-z0-9_.-]+$/.test(slug);

Astro.response.headers.set(
  "Cache-Control",
  "public, s-maxage=21600, stale-while-revalidate=86400",
);

const repoData = isValidSlug ? await getRepoReadmeData(slug) : null;

let readmeHtml = "";
let hadRenderError = false;

if (repoData?.readme) {
  const rendered = await renderReadmeToHtml(repoData.readme, {
    owner: repoData.owner,
    repo: repoData.repo,
    branch: repoData.defaultBranch,
  });
  readmeHtml = rendered.html;
  hadRenderError = rendered.hadError;
}

const notFound = !repoData || !repoData.readme;

if (notFound) {
  Astro.response.status = 404;
}
---

<BaseLayout
  title={slug ? `${slug} README` : "Project"}
  description="Repository README rendered from GitHub source."
  pathname={pathname}
>
  <PageShell pathname={pathname}>
    <section class="space-y-6">
      <div class="flex flex-wrap items-center justify-between gap-3">
        <a
          href="/projects"
          class="focus-ring mono inline-flex items-center gap-2 rounded-md border border-[var(--border-soft)] px-3 py-2 text-xs uppercase tracking-[0.15em] text-[var(--text-2)] transition hover:border-[var(--border-strong)] hover:text-[var(--text-1)]"
        >
          <ArrowLeft size={14} />
          back
        </a>

        {
          repoData && (
            <a
              href={repoData.repoUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="focus-ring mono inline-flex items-center gap-2 rounded-md border border-[var(--border-soft)] px-3 py-2 text-xs uppercase tracking-[0.15em] text-[var(--text-2)] transition hover:border-[var(--border-strong)] hover:text-[var(--text-1)]"
            >
              <ExternalLink size={14} />
              open on GitHub
            </a>
          )
        }
      </div>

      {
        notFound ? (
          <EmptyState
            title="README not found"
            description="This repository exists without a readable README in the expected location."
          />
        ) : (
          <ReadmeArticle html={readmeHtml} hadError={hadRenderError} repoUrl={repoData.repoUrl} />
        )
      }
    </section>
  </PageShell>
</BaseLayout>

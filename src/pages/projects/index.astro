---
import ContributionGrid from "@/components/astro/ContributionGrid.astro";
import EmptyState from "@/components/astro/EmptyState.astro";
import ProjectsGrid from "@/components/astro/ProjectsGrid.astro";
import { getProjectsOverview } from "@/lib/server/github";
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageShell from "@/layouts/PageShell.astro";

export const prerender = false;

const pathname = "/projects";

Astro.response.headers.set(
  "Cache-Control",
  "public, s-maxage=600, stale-while-revalidate=3600",
);

const { username, repos, contributions } = await getProjectsOverview();
---

<BaseLayout
  title="Projects"
  description="Featured repositories and contribution activity."
  pathname={pathname}
>
  <PageShell pathname={pathname} mainClass="px-[max(24px,4vw)] pb-20 pt-[max(40px,5vh)]">
    <section>
      <header class="mb-10 opacity-100">
        <div class="mb-2">
          <span class="mono text-[9px] tracking-[0.25em] text-[rgba(49,116,143,0.5)]">/contributions</span>
        </div>
        <h1 class="mono m-0 mb-[6px] text-[clamp(26px,5vw,44px)] font-bold tracking-[-0.01em] text-[rgb(224,222,244)]">
          PROJECTS
        </h1>
        <p class="m-0 mb-10 mt-0 max-w-[480px] text-[13px] leading-[1.65] text-[rgba(144,140,170,0.8)]">
          Open-source work, personal tools, and shipped products.
        </p>
      </header>

      <div class="opacity-100">
        <ContributionGrid username={username} calendar={contributions} />
      </div>

      <div class="mb-8 mt-8 h-px bg-[rgba(64,61,82,0.5)]"></div>

      <section>
        <div class="mb-10 flex items-center gap-4">
          <span class="mono text-[10px] tracking-[0.2em] text-[rgba(49,116,143,0.5)]">/featured_projects</span>
          <div class="h-px w-10 bg-gradient-to-r from-[rgba(49,116,143,0.45)] to-transparent"></div>
          <h2 class="mono m-0 text-[11px] font-normal uppercase tracking-[0.25em] text-[rgba(224,222,244,0.75)]">
            Featured Projects
          </h2>
          <div class="h-px flex-1 bg-[rgba(64,61,82,0.8)]"></div>
        </div>

        {
          repos.length > 0 ? (
            <ProjectsGrid repos={repos} />
          ) : (
            <EmptyState
              title="No featured repositories"
              description="Featured projects are temporarily unavailable."
            />
          )
        }
      </section>
    </section>
  </PageShell>
</BaseLayout>

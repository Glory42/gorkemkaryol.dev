---
import BooksShelf from "@/components/astro/BooksShelf.astro";
import FavoriteGrid from "@/components/astro/FavoriteGrid.astro";
import { getCurrentlyReadingWithStatus } from "@/lib/server/literal";
import { favorites, interestsIntro } from "@/lib/utils/content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageShell from "@/layouts/PageShell.astro";

export const prerender = false;

const pathname = "/interests";

Astro.response.headers.set(
  "Cache-Control",
  "public, s-maxage=1800, stale-while-revalidate=7200",
);

const { books, hasError } = await getCurrentlyReadingWithStatus(3);
---

<BaseLayout
  title="Interests"
  description="Favorites and currently reading shelf from Literal."
  pathname={pathname}
>
  <PageShell pathname={pathname} mainClass="px-[max(24px,4vw)] pb-20 pt-[max(40px,5vh)]">
    <section>
      <header class="opacity-100">
        <div class="mb-2">
          <span class="mono text-[9px] tracking-[0.25em] text-[rgba(49,116,143,0.5)]">/interests</span>
        </div>
        <h1 class="mono m-0 mb-[6px] text-[clamp(26px,5vw,44px)] font-bold tracking-[-0.01em] text-[rgb(224,222,244)]">
          INTERESTS
        </h1>
      </header>

      <section class="mt-6 max-w-[680px]">
        <div class="relative border border-[rgba(64,61,82,0.8)] bg-[rgba(31,29,46,0.45)] px-6 py-5">
          <span class="pointer-events-none absolute left-0 top-0 h-[7px] w-[7px] border-l border-t border-[rgba(49,116,143,0.28)]"></span>
          <span class="pointer-events-none absolute right-0 top-0 h-[7px] w-[7px] border-r border-t border-[rgba(49,116,143,0.28)]"></span>
          <span class="pointer-events-none absolute bottom-0 left-0 h-[7px] w-[7px] border-b border-l border-[rgba(49,116,143,0.28)]"></span>
          <span class="pointer-events-none absolute bottom-0 right-0 h-[7px] w-[7px] border-b border-r border-[rgba(49,116,143,0.28)]"></span>

          <p class="mono mb-3 text-[8px] tracking-[0.2em] text-[rgba(49,116,143,0.5)]">// ABOUT INTERESTS</p>
          <p class="m-0 text-[13px] leading-[1.72] text-[rgba(144,140,170,0.9)]">{interestsIntro}</p>
        </div>
      </section>

      <section class="mb-[60px] mt-12">
        <div class="mb-10 flex items-center gap-4">
          <span class="mono text-[10px] tracking-[0.2em] text-[rgba(49,116,143,0.5)]">SIG.01</span>
          <div class="h-px w-10 bg-gradient-to-r from-[rgba(49,116,143,0.45)] to-transparent"></div>
          <h2 class="mono m-0 text-[11px] font-normal uppercase tracking-[0.25em] text-[rgba(224,222,244,0.75)]">
            Favorites
          </h2>
          <div class="h-px flex-1 bg-[rgba(64,61,82,0.8)]"></div>
        </div>

        <FavoriteGrid items={favorites} />
      </section>

      <section>
        <div class="mb-10 flex items-center gap-4">
          <span class="mono text-[10px] tracking-[0.2em] text-[rgba(49,116,143,0.5)]">SIG.02</span>
          <div class="h-px w-10 bg-gradient-to-r from-[rgba(49,116,143,0.45)] to-transparent"></div>
          <h2 class="mono m-0 text-[11px] font-normal uppercase tracking-[0.25em] text-[rgba(224,222,244,0.75)]">
            Currently Reading
          </h2>
          <div class="h-px flex-1 bg-[rgba(64,61,82,0.8)]"></div>
        </div>

        <BooksShelf books={books} hasError={hasError} />
      </section>
    </section>
  </PageShell>
</BaseLayout>

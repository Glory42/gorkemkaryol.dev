---
import { ExternalLink, Star } from "lucide-react";
import type { FeaturedRepository } from "@/types/github";

interface Props {
  repos: FeaturedRepository[];
}

const { repos } = Astro.props;
---

<div class="grid grid-cols-[repeat(auto-fill,minmax(min(100%,340px),1fr))] gap-3">
  {
    repos.map((repo, index) => {
      const cardId = String(index + 1).padStart(3, "0");
      const tags: string[] =
        repo.topics.length > 0 ? repo.topics.slice(0, 4) : [repo.primaryLanguage?.name ?? "Repository"];

      return (
        <article class="group relative flex h-full flex-col border border-[rgba(64,61,82,0.8)] bg-[rgba(31,29,46,0.55)] p-[22px]">
          <a
            href={`/projects/${repo.name}`}
            class="focus-ring absolute inset-0 z-10"
            aria-label={`Open ${repo.name} README page`}
          ></a>

          <span class="pointer-events-none absolute left-0 top-0 h-[8px] w-[8px] border-l border-t border-[rgba(196,167,231,0.25)]"></span>
          <span class="pointer-events-none absolute right-0 top-0 h-[8px] w-[8px] border-r border-t border-[rgba(196,167,231,0.25)]"></span>
          <span class="pointer-events-none absolute bottom-0 left-0 h-[8px] w-[8px] border-b border-l border-[rgba(196,167,231,0.25)]"></span>
          <span class="pointer-events-none absolute bottom-0 right-0 h-[8px] w-[8px] border-b border-r border-[rgba(196,167,231,0.25)]"></span>

          <div class="relative z-[11] mb-3 flex items-center justify-between">
            <span class="mono text-[8px] tracking-[0.12em] text-[rgba(110,106,134,0.7)]">PROJ-{cardId}</span>
            <span class="inline-flex items-center gap-1">
              <Star
                size={9}
                className={repo.stargazerCount > 0 ? "text-[rgba(246,193,119,0.7)]" : "text-[rgba(110,106,134,0.7)]"}
                fill={repo.stargazerCount > 0 ? "rgba(246,193,119,0.7)" : "none"}
              />
              <span class="mono text-[9px] text-[rgba(110,106,134,0.7)]">{repo.stargazerCount}</span>
            </span>
          </div>

          <h3 class="mono relative z-[11] mb-[10px] text-[13px] font-semibold leading-[1.3] tracking-[0.03em] text-[rgb(224,222,244)] group-hover:text-[rgb(196,167,231)]">
            {repo.name}
          </h3>

          <p class="relative z-[11] mb-4 flex-1 text-[12px] leading-[1.65] text-[rgba(144,140,170,0.88)]">{repo.description}</p>

          <div class="relative z-[11] flex items-center justify-between gap-3">
            <div class="flex flex-wrap gap-[5px]">
              {
                tags.map((tag) => (
                  <span class="mono border border-[rgba(49,116,143,0.2)] px-1.5 py-[2px] text-[8px] tracking-[0.1em] text-[rgba(49,116,143,0.75)]">
                    {tag}
                  </span>
                ))
              }
            </div>

            <a
              href={repo.url}
              target="_blank"
              rel="noopener noreferrer"
              class="focus-ring relative z-[12] text-[rgba(49,116,143,0.55)] transition-colors hover:text-[rgba(49,116,143,0.95)]"
              aria-label={`Open ${repo.name} on GitHub`}
            >
              <ExternalLink size={11} />
            </a>
          </div>

          <span class="absolute bottom-0 left-0 right-0 h-px origin-left scale-x-0 bg-[rgb(196,167,231)] transition-transform duration-200 group-hover:scale-x-100"></span>
        </article>
      );
    })
  }
</div>

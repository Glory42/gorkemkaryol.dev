---
interface Props {
  html: string;
  hadError: boolean;
  repoUrl: string;
}

const { html, hadError, repoUrl } = Astro.props;
---

<article class="panel p-5 md:p-8">
  {
    hadError && (
      <p class="mb-4 rounded-md border border-[var(--accent-amber)] bg-[#2e230f] px-3 py-2 text-sm text-[#ffd88f]">
        README rendering fell back to plain text due to a parsing issue. You can still view the original file on
        <a
          href={repoUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="ml-1 underline underline-offset-2"
        >
          GitHub
        </a>
        .
      </p>
    )
  }

  <div class="readme-prose prose prose-invert max-w-none" set:html={html}></div>
</article>
